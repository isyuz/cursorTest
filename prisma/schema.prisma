generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      String    @default("SALES") // ADMIN | MANAGER | SALES
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customers Customer[] @relation("UserCustomers")
  projects  Project[]  @relation("UserProjects")
  leads     Lead[]     @relation("UserLeads")
  activities Activity[] @relation("UserActivities")
}

// 线索：来源渠道、状态、负责人、下次跟进时间
model Lead {
  id           Int       @id @default(autoincrement())
  name         String    // 公司/联系人名称
  contactName  String?
  contactPhone String?
  contactEmail String?
  source       String?   // 来源渠道
  status       String    @default("NEW") // NEW | CONTACTED | INVALID | CONVERTED
  nextFollowAt DateTime?
  remark       String?
  ownerId      Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner      User       @relation("UserLeads", fields: [ownerId], references: [id])
  activities Activity[] @relation("LeadActivities")
}

// 跟进记录：时间、方式、内容
model Activity {
  id         Int       @id @default(autoincrement())
  type       String    // CALL | WECHAT | EMAIL | MEETING | OTHER
  content    String
  customerId Int?
  leadId     Int?
  userId     Int
  createdAt  DateTime  @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation("LeadActivities", fields: [leadId], references: [id], onDelete: SetNull)
  user     User     @relation("UserActivities", fields: [userId], references: [id])
}

model Referrer {
  id        Int       @id @default(autoincrement())
  name      String
  type      String    // EMPLOYEE | CUSTOMER | PARTNER
  contact   String?
  remark    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customers Customer[] @relation("ReferrerCustomers")
  projects  Project[]  @relation("ReferrerProjects")
}

model Customer {
  id           Int       @id @default(autoincrement())
  name         String
  contactName  String?
  contactPhone String?
  contactEmail String?
  industry     String?
  size         String?
  tags         String?
  ownerId      Int
  referrerId   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner      User       @relation("UserCustomers", fields: [ownerId], references: [id])
  referrer   Referrer?  @relation("ReferrerCustomers", fields: [referrerId], references: [id])
  projects   Project[]
  activities Activity[]
}

model Project {
  id               Int       @id @default(autoincrement())
  name             String
  customerId       Int
  ownerId          Int
  referrerId       Int?
  amount           Float
  stage            String    @default("LEAD") // LEAD | QUALIFIED | PROPOSAL | NEGOTIATION | WON | LOST
  commissionType   String    @default("NONE") // NONE | PERCENTAGE | FIXED
  commissionRate   Float?
  commissionAmount Float?
  expectedCloseAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id])
  owner    User      @relation("UserProjects", fields: [ownerId], references: [id])
  referrer Referrer? @relation("ReferrerProjects", fields: [referrerId], references: [id])
}

